# Copy file này thành `.env` ở thư mục gốc project để chạy Docker Compose.
# Không commit `.env` lên Git.

JWT_SECRET=change-me-to-a-strong-random-string
# Docker dev (frontend Vite): thêm http://localhost:5173 nếu CORS báo lỗi
FRONTEND_URL=http://localhost:5173,http://localhost:3000

# Gmail API (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

