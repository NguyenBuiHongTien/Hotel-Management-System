# Copy this file to `.env` in the project root for Docker Compose.
# Do not commit `.env` to Git.

JWT_SECRET=change-me-to-a-strong-random-string
# Docker dev (Vite frontend): add http://localhost:5173 if CORS fails
FRONTEND_URL=http://localhost:5173,http://localhost:3000

# Gmail API (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

