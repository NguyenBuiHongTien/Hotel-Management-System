MONGODB_URL=mongodb://localhost:27017/hotel_management
JWT_SECRET=change-me-to-a-strong-random-string-at-least-16-chars
# Multiple origins: comma-separated. Vite dev: 5173; CRA/nginx prod: 3000
FRONTEND_URL=http://localhost:5173,http://localhost:3000
PORT=5000

# Gmail API (optional — configure OAuth2 to send mail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# From address (usually the authorized Gmail). May be empty — backend falls back to Gmail profile.
GMAIL_SENDER_EMAIL=

# Booking reminders (email)
BOOKING_REMINDER_ENABLED=true
BOOKING_REMINDER_INTERVAL_MINUTES=15
CHECKIN_REMINDER_HOURS_BEFORE=24
CHECKOUT_REMINDER_HOURS_BEFORE=3

